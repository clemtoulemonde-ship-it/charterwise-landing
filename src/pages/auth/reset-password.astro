---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Reset Password — CharterWise">
  <header class="bg-[#1B3A5C]">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center gap-2.5">
      <img src="/icon.png" alt="CharterWise" class="h-8 w-8 rounded-lg object-cover" />
      <span class="text-white font-bold text-xl tracking-tight">CharterWise</span>
    </nav>
  </header>

  <main class="max-w-md mx-auto px-6 py-20">
    <h1 class="text-3xl font-bold text-[#1B3A5C] mb-8">
      Reset your password
    </h1>

    <!-- States: loading | error | form | success -->
    <div id="state-loading" class="text-center py-12">
      <div class="inline-block w-8 h-8 border-4 border-[#1B3A5C] border-t-transparent rounded-full animate-spin"></div>
      <p class="text-[#6B7280] mt-4 text-sm">Verifying your reset link…</p>
    </div>

    <div id="state-error" class="hidden">
      <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
        <p id="error-message" class="text-red-700 text-sm">This link has expired or already been used. Please request a new password reset from the app.</p>
      </div>
      <p class="text-[#6B7280] text-sm">
        Open CharterWise on your phone and tap <strong>Forgot password</strong> to get a new link.
      </p>
    </div>

    <form id="state-form" class="hidden space-y-5">
      <div>
        <label for="password" class="block text-sm font-semibold text-[#374151] mb-1.5">New password</label>
        <input
          id="password"
          type="password"
          autocomplete="new-password"
          placeholder="At least 6 characters"
          class="w-full border-2 border-[#E5E7EB] rounded-xl px-4 py-3 text-[#111827] text-base focus:outline-none focus:border-[#1B3A5C] transition-colors"
        />
      </div>
      <div>
        <label for="confirm" class="block text-sm font-semibold text-[#374151] mb-1.5">Confirm password</label>
        <input
          id="confirm"
          type="password"
          autocomplete="new-password"
          placeholder="Repeat your new password"
          class="w-full border-2 border-[#E5E7EB] rounded-xl px-4 py-3 text-[#111827] text-base focus:outline-none focus:border-[#1B3A5C] transition-colors"
        />
      </div>
      <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-3">
        <p id="form-error-message" class="text-red-700 text-sm"></p>
      </div>
      <button
        id="submit-btn"
        type="submit"
        class="w-full bg-[#1B3A5C] text-white font-bold text-base rounded-xl py-3.5 hover:bg-[#2E5480] transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
      >
        Set new password
      </button>
    </form>

    <div id="state-success" class="hidden text-center py-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-6">
        <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-[#111827] mb-2">Password updated</h2>
      <p class="text-[#6B7280] text-sm mb-8">
        Your password has been changed. Open the app on your phone to sign in.
      </p>
      <a
        href="charterwise://auth/login"
        class="inline-block bg-[#1B3A5C] text-white font-bold text-sm rounded-xl px-6 py-3 hover:bg-[#2E5480] transition-colors"
      >
        Open CharterWise
      </a>
    </div>
  </main>

  <footer class="bg-[#1B3A5C] text-white/60 py-8 mt-20">
    <p class="text-center text-sm">© {new Date().getFullYear()} CharterWise</p>
  </footer>
</Layout>

<script>
  // Supabase config — anon key is public (embedded in iOS app binary)
  const SUPABASE_URL = 'https://encnmjtyoemmgcqqhhiv.supabase.co';
  const SUPABASE_ANON_KEY = 'sb_publishable_Y3VxQhw_I75207SxIz1yyQ_eVFp9S3i';

  function show(id: string) {
    ['state-loading', 'state-error', 'state-form', 'state-success'].forEach((s) => {
      const el = document.getElementById(s);
      if (el) el.classList.toggle('hidden', s !== id);
    });
  }

  function showFormError(msg: string) {
    const box = document.getElementById('form-error')!;
    const text = document.getElementById('form-error-message')!;
    text.textContent = msg;
    box.classList.remove('hidden');
  }

  async function init() {
    // Supabase PKCE flow sends ?code= in the URL
    const params = new URLSearchParams(window.location.search);
    const code = params.get('code');

    if (!code) {
      show('state-error');
      return;
    }

    try {
      // Exchange the PKCE code for a session using fetch directly
      // (avoids bundling the full supabase-js client)
      const res = await fetch(`${SUPABASE_URL}/auth/v1/token?grant_type=pkce`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON_KEY,
        },
        body: JSON.stringify({ auth_code: code }),
      });

      const data = await res.json();

      if (!res.ok || !data.access_token) {
        show('state-error');
        const errEl = document.getElementById('error-message');
        if (errEl && data.error_description) errEl.textContent = data.error_description;
        return;
      }

      // Store tokens so the update call can use them
      const accessToken: string = data.access_token;

      show('state-form');

      const form = document.getElementById('state-form') as HTMLFormElement;
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const password = (document.getElementById('password') as HTMLInputElement).value;
        const confirm = (document.getElementById('confirm') as HTMLInputElement).value;

        document.getElementById('form-error')?.classList.add('hidden');

        if (password.length < 8) {
          showFormError('Password must be at least 8 characters.');
          return;
        }
        if (password !== confirm) {
          showFormError('Passwords do not match.');
          return;
        }

        const btn = document.getElementById('submit-btn') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Saving…';

        const updateRes = await fetch(`${SUPABASE_URL}/auth/v1/user`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': `Bearer ${accessToken}`,
          },
          body: JSON.stringify({ password }),
        });

        if (updateRes.ok) {
          show('state-success');
        } else {
          const err = await updateRes.json();
          btn.disabled = false;
          btn.textContent = 'Set new password';
          showFormError(err.message ?? 'Something went wrong. Please try again.');
        }
      });

    } catch {
      show('state-error');
    }
  }

  init();
</script>
