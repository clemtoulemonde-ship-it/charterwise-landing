---
import Layout from '../layouts/Layout.astro';

const TESTFLIGHT_URL = 'https://testflight.apple.com/join/TTgDqpmY';
---

<Layout>
  <!-- NAV -->
  <header class="sticky top-0 z-50 bg-[#1B3A5C] shadow-md">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/icon.png" alt="CharterWise" class="h-11 w-11 rounded-xl object-cover" />
        <span class="text-white font-bold text-2xl tracking-tight">CharterWise</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-white/80">
        <a href="#how-it-works" class="hover:text-white transition-colors">How it works</a>
        <a href="#features" class="hover:text-white transition-colors">Features</a>
        <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
      </div>
      <a
        href={TESTFLIGHT_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-[#D4A843] hover:bg-[#B8902F] text-[#1B3A5C] font-bold text-sm px-5 py-2.5 rounded-lg transition-colors"
      >
        Get the app
      </a>
    </nav>
  </header>

  <main>
    <!-- HERO -->
    <section class="relative bg-[#1B3A5C] text-white min-h-[90vh] flex items-center overflow-hidden">
      <div class="absolute inset-0 opacity-5"
        style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 32px 32px;">
      </div>

      <div class="relative max-w-6xl mx-auto px-6 py-24 grid md:grid-cols-2 gap-16 items-center w-full">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/10 text-white/90 text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
            iOS Beta — Free
          </div>
          <h1 style="font-family:'Playfair Display',Georgia,serif" class="text-5xl md:text-6xl font-bold leading-tight mb-6">
            Know your boat<br />before you sail.
          </h1>
          <p class="text-white/75 text-lg leading-relaxed mb-10 max-w-lg">
            CharterWise is the community app where charterers share real pick-up reports, flag issues, and score the condition of every boat — so you arrive prepared, not surprised.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={TESTFLIGHT_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-[#D4A843] hover:bg-[#B8902F] text-[#1B3A5C] font-bold text-base px-8 py-4 rounded-xl transition-colors text-center"
            >
              Join the iOS Beta
            </a>
            <a
              href="#android"
              class="border border-white/30 hover:border-white text-white font-semibold text-base px-8 py-4 rounded-xl transition-colors text-center"
            >
              Notify me on Android
            </a>
          </div>
          <p class="text-white/40 text-sm mt-4">Free · iOS now · Android coming soon</p>
        </div>

        <!-- Demo card -->
        <div class="hidden md:flex justify-center">
          <div class="bg-white rounded-2xl shadow-2xl p-6 w-72">
            <p class="text-xs font-bold uppercase tracking-widest text-[#6B7280] mb-3">CONDITION</p>
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xl">✓</span>
              <span class="font-bold text-[#10B981] text-lg">Good to go</span>
            </div>
            <div class="border-t border-[#E5E7EB] pt-4 mb-4">
              <p class="text-xs font-bold uppercase tracking-widest text-[#6B7280] mb-3">BY CATEGORY</p>
              <div class="space-y-2">
                {[
                  { label: 'Safety', color: '#10B981' },
                  { label: 'Mechanical', color: '#F59E0B' },
                  { label: 'Navigation', color: '#10B981' },
                  { label: 'Comfort', color: '#10B981' },
                  { label: 'Inventory', color: '#10B981' },
                ].map(({ label, color }) => (
                  <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background:${color}`}></span>
                    <span class="text-sm text-[#111827]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
            <p class="text-xs text-[#6B7280]">Based on 3 pick-up reports · 1 open issue</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust bar -->
    <section class="bg-white border-b border-[#E5E7EB]">
      <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-12 text-sm text-[#6B7280] font-medium">
        <div class="flex items-center gap-2"><span>⚓</span> Community-driven</div>
        <div class="flex items-center gap-2"><span>🛡</span> Real pick-up reports</div>
        <div class="flex items-center gap-2"><span>★</span> Verified charterer reviews</div>
      </div>
    </section>

    <!-- PROBLEM -->
    <section class="bg-[#F8F6F1] py-24">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-xs font-bold uppercase tracking-widest text-[#D4A843] mb-4">The problem</p>
        <h2 style="font-family:'Playfair Display',Georgia,serif" class="text-4xl font-bold text-[#1B3A5C] mb-8 leading-tight">
          You've arrived to a boat that wasn't ready.<br class="hidden sm:block" /> We've all been there.
        </h2>
        <div class="text-[#6B7280] text-lg leading-relaxed space-y-5 text-left">
          <p>
            You book months in advance. You pack carefully. You brief the crew. Then you arrive at the marina and discover the engine cuts out above 2,000 rpm, the port head is blocked, and the main sail track is seized — none of which was mentioned in any listing.
          </p>
          <p>
            Charter companies have every incentive to minimise reported issues. Listing photos are taken once. Reviews on booking platforms rate the holiday, not the boat.
          </p>
          <p class="font-semibold text-[#1B3A5C]">
            CharterWise is built specifically for the handover moment: the pick-up report, filed by the sailor who just stepped off.
          </p>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how-it-works" class="bg-white py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-xs font-bold uppercase tracking-widest text-[#D4A843] mb-4">How it works</p>
          <h2 style="font-family:'Playfair Display',Georgia,serif" class="text-4xl font-bold text-[#1B3A5C]">The charter journey, finally tracked.</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            {
              step: '1',
              icon: '🗺',
              title: 'Plan',
              desc: 'Browse boats and check condition scores and reviews from fellow charterers before you book. Filter by hull type, region, and issue count.',
            },
            {
              step: '2',
              icon: '📋',
              title: 'Pick-up Report',
              desc: "At handover, walk through 6 categories — rigging, engine, electronics, safety, hull, interior. Flag issues, attach photos, and your report immediately updates the boat's live condition score.",
            },
            {
              step: '3',
              icon: '⭐',
              title: 'Review',
              desc: 'At the end of your charter, leave a structured review with category ratings. Issues that persisted carry forward to the next sailor automatically.',
            },
          ].map(({ step, icon, title, desc }) => (
            <div class="bg-[#F8F6F1] rounded-2xl p-8">
              <div class="flex items-center gap-4 mb-5">
                <div class="w-10 h-10 rounded-full bg-[#1B3A5C] text-white text-sm font-bold flex items-center justify-center flex-shrink-0">
                  {step}
                </div>
                <span class="text-2xl">{icon}</span>
                <h3 class="font-bold text-xl text-[#1B3A5C]">{title}</h3>
              </div>
              <p class="text-[#6B7280] leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" class="bg-[#F8F6F1] py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-xs font-bold uppercase tracking-widest text-[#D4A843] mb-4">Features</p>
          <h2 style="font-family:'Playfair Display',Georgia,serif" class="text-4xl font-bold text-[#1B3A5C]">Built for sailors, by sailors.</h2>
        </div>

        <div class="space-y-20">
          <!-- Feature 1 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-[#D4A843] mb-3">Condition Score</p>
              <h3 style="font-family:'Playfair Display',Georgia,serif" class="text-3xl font-bold text-[#1B3A5C] mb-5">A live health score for every boat.</h3>
              <p class="text-[#6B7280] leading-relaxed mb-6">
                Every pick-up report contributes to a severity-weighted condition score. Safety issues weigh more than cosmetic ones. The score updates as new reports come in — so a boat that's been repaired recovers its rating automatically.
              </p>
              <div class="space-y-3">
                {[
                  { color: '#10B981', bg: '#10B98118', label: 'Good to go', desc: 'No significant open issues' },
                  { color: '#F59E0B', bg: '#F59E0B18', label: 'Minor things', desc: 'Some non-critical issues flagged' },
                  { color: '#EF4444', bg: '#EF444418', label: 'Check required', desc: 'Critical or safety issues open' },
                ].map(({ color, bg, label, desc }) => (
                  <div class="flex items-center gap-4 bg-white rounded-xl px-4 py-3 border border-[#E5E7EB]">
                    <span class="w-3 h-3 rounded-full flex-shrink-0" style={`background:${color}`}></span>
                    <span class="font-semibold text-sm" style={`color:${color}`}>{label}</span>
                    <span class="text-sm text-[#6B7280]">— {desc}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="bg-white rounded-2xl p-8 border border-[#E5E7EB] shadow-sm">
              <p class="text-xs font-bold uppercase tracking-widest text-[#6B7280] mb-5">Live boat condition</p>
              <div class="space-y-4">
                {[
                  { name: 'Beneteau Oceanis 45', detail: 'No open issues', label: 'Good to go', color: '#10B981' },
                  { name: 'Jeanneau Sun Odyssey 440', detail: '2 open issues', label: 'Minor things', color: '#F59E0B' },
                  { name: 'Lagoon 42 Catamaran', detail: '4 open issues', label: 'Check required', color: '#EF4444' },
                ].map(({ name, detail, label, color }) => (
                  <div class="flex items-center justify-between py-3 border-b border-[#E5E7EB] last:border-0">
                    <div>
                      <p class="font-semibold text-sm text-[#111827]">{name}</p>
                      <p class="text-xs text-[#6B7280]">{detail}</p>
                    </div>
                    <span class="text-xs font-bold px-3 py-1.5 rounded-full" style={`color:${color}; background:${color}18`}>{label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="order-2 md:order-1 bg-white rounded-2xl p-8 border border-[#E5E7EB] shadow-sm">
              <p class="text-xs font-bold uppercase tracking-widest text-[#6B7280] mb-5">Pick-up report categories</p>
              <div class="grid grid-cols-2 gap-3">
                {[
                  { icon: '⛵', label: 'Rigging' },
                  { icon: '⚙️', label: 'Engine' },
                  { icon: '🧭', label: 'Electronics' },
                  { icon: '🛡', label: 'Safety' },
                  { icon: '⚓', label: 'Hull & Deck' },
                  { icon: '🛏', label: 'Interior' },
                ].map(({ icon, label }) => (
                  <div class="flex items-center gap-3 bg-[#F8F6F1] rounded-xl px-4 py-3">
                    <span>{icon}</span>
                    <span class="font-semibold text-sm text-[#1B3A5C]">{label}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="order-1 md:order-2">
              <p class="text-xs font-bold uppercase tracking-widest text-[#D4A843] mb-3">Pick-up Report</p>
              <h3 style="font-family:'Playfair Display',Georgia,serif" class="text-3xl font-bold text-[#1B3A5C] mb-5">The handover inspection, digitised.</h3>
              <p class="text-[#6B7280] leading-relaxed">
                File your inspection before you leave the dock. Walk through six categories, flag what you find, and attach photos directly to each issue. Your report is timestamped, attached to the boat's permanent record, and visible to the next charterer.
              </p>
            </div>
          </div>

          <!-- Feature 3 -->
          <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-[#D4A843] mb-3">Reviews</p>
              <h3 style="font-family:'Playfair Display',Georgia,serif" class="text-3xl font-bold text-[#1B3A5C] mb-5">Reviews that actually cover what matters.</h3>
              <p class="text-[#6B7280] leading-relaxed">
                Category ratings for sails, engine, navigation gear, safety equipment, and interior — not just a vibe score. Review items flag specific positives and persistent issues. Photos attached to the systems that matter, not just the sunset from the cockpit.
              </p>
            </div>
            <div class="bg-white rounded-2xl p-8 border border-[#E5E7EB] shadow-sm">
              <div class="flex items-start justify-between mb-5">
                <div>
                  <p class="font-bold text-[#111827]">Beneteau Oceanis 45</p>
                  <p class="text-sm text-[#6B7280]">Croatia · June 2025 · 7 days</p>
                </div>
                <span class="text-[#D4A843] text-lg">★★★★☆</span>
              </div>
              <div class="space-y-3">
                {[
                  { label: 'Rigging', rating: 5 },
                  { label: 'Engine', rating: 4 },
                  { label: 'Electronics', rating: 4 },
                  { label: 'Safety', rating: 5 },
                  { label: 'Comfort', rating: 4 },
                ].map(({ label, rating }) => (
                  <div class="flex items-center gap-3">
                    <span class="text-sm text-[#6B7280] w-24 flex-shrink-0">{label}</span>
                    <div class="flex-1 bg-[#F5F5F5] rounded-full h-1.5">
                      <div class="bg-[#D4A843] h-1.5 rounded-full" style={`width:${rating / 5 * 100}%`}></div>
                    </div>
                    <span class="text-sm font-semibold text-[#111827]">{rating}/5</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DOWNLOAD CTA -->
    <section id="android" class="bg-[#1B3A5C] py-24">
      <div class="max-w-2xl mx-auto px-6 text-center">
        <h2 style="font-family:'Playfair Display',Georgia,serif" class="text-4xl font-bold text-white mb-5">Ready to charter smarter?</h2>
        <p class="text-white/70 text-lg mb-10">Join the iOS beta on TestFlight — free, no subscription.</p>

        <a
          href={TESTFLIGHT_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-[#D4A843] hover:bg-[#B8902F] text-[#1B3A5C] font-bold text-lg px-10 py-5 rounded-xl transition-colors mb-14"
        >
          Download on TestFlight
        </a>

        <div class="border-t border-white/20 pt-10">
          <p class="text-white/80 font-semibold mb-1">Android coming soon</p>
          <p class="text-white/50 text-sm mb-6">Leave your email and we'll notify you the moment it's live.</p>
          <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input
              type="email"
              placeholder="your@email.com"
              required
              class="flex-1 bg-white/10 border border-white/20 text-white placeholder-white/40 rounded-xl px-5 py-3.5 text-sm focus:outline-none focus:border-[#D4A843] transition-colors"
            />
            <button
              type="submit"
              class="bg-white text-[#1B3A5C] font-bold text-sm px-6 py-3.5 rounded-xl hover:bg-[#F8F6F1] transition-colors whitespace-nowrap"
            >
              Notify me
            </button>
          </form>
          <p id="waitlist-confirm" class="text-[#D4A843] text-sm mt-3 hidden">You're on the list — we'll be in touch!</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="bg-white py-24">
      <div class="max-w-2xl mx-auto px-6">
        <div class="text-center mb-12">
          <p class="text-xs font-bold uppercase tracking-widest text-[#D4A843] mb-4">FAQ</p>
          <h2 style="font-family:'Playfair Display',Georgia,serif" class="text-4xl font-bold text-[#1B3A5C]">Common questions</h2>
        </div>
        <div class="space-y-3">
          {[
            {
              q: 'Is CharterWise free?',
              a: 'Yes — completely free during beta. No subscription, no in-app purchases.',
            },
            {
              q: 'What boats are in the database?',
              a: 'Primarily Mediterranean and Adriatic — Croatia, Greece, Turkey, Italy. Coverage grows with every pick-up report filed.',
            },
            {
              q: 'How do I know reports are real?',
              a: 'Pick-up reports are time-gated to your charter window — you can only file one within a day of your charter start date. Each report is tied to a verified charter plan.',
            },
            {
              q: "I'm a charter company — is this bad for my fleet?",
              a: "Only if your fleet isn't maintained. Companies with well-kept boats will be rewarded in the data. Issues that get fixed improve the condition score immediately.",
            },
            {
              q: 'When is Android available?',
              a: "Soon. Sign up for the waitlist above and you'll be the first to know.",
            },
          ].map(({ q, a }) => (
            <details class="group bg-[#F8F6F1] rounded-xl border border-[#E5E7EB] overflow-hidden">
              <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer font-semibold text-[#111827] list-none select-none">
                {q}
                <span class="text-[#6B7280] transition-transform group-open:rotate-180 flex-shrink-0 text-xs">▾</span>
              </summary>
              <p class="px-6 pb-5 text-[#6B7280] leading-relaxed">{a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="bg-[#1B3A5C] text-white/60 py-10">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <div class="flex items-center gap-2.5">
        <img src="/icon.png" alt="CharterWise" class="h-6 w-6 rounded-md object-cover opacity-80" />
        <span>
          <span class="font-bold text-white">CharterWise</span>
          <span class="ml-2">— Know your boat before you sail.</span>
        </span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
        <a href="mailto:hello@charterwise.app" class="hover:text-white transition-colors">Contact</a>
        <a href={TESTFLIGHT_URL} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">TestFlight</a>
      </div>
    </div>
    <p class="max-w-6xl mx-auto px-6 mt-6 text-xs text-white/30 text-center sm:text-left">
      © {new Date().getFullYear()} CharterWise. Built by sailors, for sailors.
    </p>
  </footer>

  <script>
    const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
    const confirm = document.getElementById('waitlist-confirm');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      // TODO: wire to Mailchimp API endpoint
      if (form) form.style.display = 'none';
      if (confirm) confirm.classList.remove('hidden');
    });
  </script>
</Layout>
